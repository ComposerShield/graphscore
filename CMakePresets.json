{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "unix-common",
      "hidden": true,
      "inherits": "common",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "windows-common",
      "hidden": true,
      "inherits": "common",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (macOS/Linux, Clang)",
      "inherits": "unix-common",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "displayName": "Release (macOS/Linux, Clang)",
      "inherits": "unix-common",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "asan-ubsan",
      "displayName": "ASan/UBSan (macOS/Linux, Clang)",
      "inherits": "debug",
      "cacheVariables": { "GRAPHSCORE_SANITIZER": "ASAN_UBSAN" }
    },
    {
      "name": "tsan",
      "displayName": "TSan (macOS/Linux, Clang)",
      "inherits": "debug",
      "cacheVariables": { "GRAPHSCORE_SANITIZER": "TSAN" }
    },
    {
      "name": "ci",
      "displayName": "CI (macOS/Linux, Clang, RelWithDebInfo)",
      "inherits": "release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "debug-windows",
      "displayName": "Debug (Windows, clang-cl)",
      "inherits": "windows-common",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release-windows",
      "displayName": "Release (Windows, clang-cl)",
      "inherits": "windows-common",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "ci-windows",
      "displayName": "CI (Windows, clang-cl, RelWithDebInfo)",
      "inherits": "release-windows",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "asan-ubsan", "configurePreset": "asan-ubsan" },
    { "name": "tsan", "configurePreset": "tsan" },
    { "name": "ci", "configurePreset": "ci" },
    { "name": "debug-windows", "configurePreset": "debug-windows" },
    { "name": "release-windows", "configurePreset": "release-windows" },
    { "name": "ci-windows", "configurePreset": "ci-windows" }
  ],
  "testPresets": [
    { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
    { "name": "release", "configurePreset": "release", "output": { "outputOnFailure": true } },
    { "name": "asan-ubsan", "configurePreset": "asan-ubsan", "output": { "outputOnFailure": true } },
    { "name": "tsan", "configurePreset": "tsan", "output": { "outputOnFailure": true } },
    { "name": "ci", "configurePreset": "ci", "output": { "outputOnFailure": true } },
    { "name": "debug-windows", "configurePreset": "debug-windows", "output": { "outputOnFailure": true } },
    { "name": "release-windows", "configurePreset": "release-windows", "output": { "outputOnFailure": true } },
    { "name": "ci-windows", "configurePreset": "ci-windows", "output": { "outputOnFailure": true } }
  ]
}
