# SPDX-License-Identifier: Apache-2.0
#
# graphscore_c_abi is a pure C99 header (ADR 0003 §1, layer 0). The root
# .clang-tidy targets C++23 GraphScore code; several of its checks are
# actively wrong here, because C has neither the constructs they suggest nor
# the freedom to change the ones they object to.
#
# Inherits everything else from the root configuration.

InheritParentConfig: true

Checks: >
  -modernize-use-using,
  -modernize-use-trailing-return-type,
  -performance-enum-size,
  -cppcoreguidelines-avoid-non-const-global-variables,
  -bugprone-reserved-identifier,
  -readability-identifier-length

# `typedef struct { ... } name_t;` is the only way to name a struct type in
# C99; `using` does not exist. -modernize-use-using above.
#
# `performance-enum-size` would have gs_result_code_t narrowed to uint8_t.
# The enum's width is part of the ABI: gs_result_t asserts sizeof 12 with a
# 4-byte code member, and narrowing it would silently break every compiled
# consumer.
#
# `bugprone-reserved-identifier` fires on the GS_STATIC_ASSERT-generated
# gs_static_assert_* typedefs and on the include guard; both are deliberate
# and namespaced.
